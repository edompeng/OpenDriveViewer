+Vec2D Arc::get_grad(double s) const
+{
+    const double dx = std::sin((M_PI / 2) - curvature * (s - s0) - hdg0);
+    const double dy = std::cos((M_PI / 2) - curvature * (s - s0) - hdg0);
+    return {{dx, dy}};
+}
