# =============================================================================
# Shared Build Settings (version-controlled)
# =============================================================================
build --cxxopt=-DPROJ_NEW_API
build --cxxopt=-I.

# Platform-specific C++ standard flags
build:linux --copt=-Werror --cxxopt=-Werror
build:macos --copt=-Werror --cxxopt=-Werror
build:windows --copt=/WX --cxxopt=/WX
build:windows --cxxopt=/wd4005
build:windows --cxxopt=/FIiterator
build:linux --cxxopt=-std=c++17
build:macos --cxxopt=-std=c++17
build:windows --cxxopt=/std:c++17
build:windows --cxxopt=/Zc:__cplusplus
build:windows --cxxopt=/permissive-

test --test_output=errors

# =============================================================================
# Import user-local overrides (.bazelrc.user is NOT version-controlled).
# This is where each developer sets QT6_ROOT and PROJ_ROOT for their machine.
# =============================================================================
try-import %workspace%/.bazelrc.user

# =============================================================================
# CI-specific settings (used in GitHub Actions)
# =============================================================================
# These are often overridden by command line arguments in ci.yml
# but provided here for documentation and local CI emulation.
build:ci --repository_cache=~/.cache/bazel-repo
build:ci --disk_cache=~/.cache/bazel-disk
build:ci --keep_going
test:ci --test_output=errors
